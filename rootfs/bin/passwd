#!/usr/bin/env bash
# Change a minibash account password in the bdb users table.
set -u

BDB_PATH="${BDB_PATH:-/var/bdb}"; export BDB_PATH
PATH=/bin:/usr/bin:/sbin:/usr/sbin

target="${1:-${USER:-root}}"
current="${USER:-root}"

if [ "$current" != "root" ] && [ "$target" != "$current" ]; then
  echo "passwd: permission denied"
  exit 1
fi

if ! /bin/bdb dump users | tail -n +2 | awk -F'\t' -v u="$target" '$1 == u { found=1 } END { exit found ? 0 : 1 }'; then
  echo "passwd: unknown user '$target'"
  exit 1
fi

printf 'New password: '
read -rs pw1 || { echo; exit 1; }
echo
printf 'Retype new password: '
read -rs pw2 || { echo; exit 1; }
echo

if [ "$pw1" != "$pw2" ]; then
  unset pw1 pw2
  echo "passwd: passwords do not match"
  exit 1
fi

if [ -z "$pw1" ]; then
  unset pw1 pw2
  echo "passwd: empty password refused"
  exit 1
fi

if ! command -v openssl >/dev/null 2>&1; then
  unset pw1 pw2
  echo "passwd: openssl is required"
  exit 1
fi

salt="$(tr -d '-' </proc/sys/kernel/random/uuid 2>/dev/null | cut -c1-16)"
if [ -z "${salt:-}" ]; then
  salt="$(date +%s%N | sha256sum | cut -c1-16)"
fi

hash="$(openssl passwd -6 -salt "$salt" "$pw1" 2>/dev/null)" || {
  unset pw1 pw2
  echo "passwd: failed to hash password"
  exit 1
}
unset pw1 pw2

/bin/bdb update users --where "username=$target" password="$hash" >/dev/null
echo "passwd: password updated for $target"
