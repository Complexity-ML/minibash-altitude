#!/usr/bin/env bash
# Typed hierarchical registry backed by the native BDB engine.
set -euo pipefail

export BDB_PATH="${BDB_PATH:-/var/bdb}"
BDB="${BDB_BIN:-/bin/bdb}"
WRITE_LOCK="${BDBREG_WRITE_LOCK:-/run/bdbreg-write.lock}"

usage() {
  cat <<'EOF'
usage: bdbreg <command> [args]

  list [PREFIX]                    list registry values below PREFIX
  get PATH                         read one value
  set PATH TYPE VALUE [OWNER]      create or replace a typed value
  delete PATH                      remove one value

types: string int bool real
EOF
}

die() {
  echo "bdbreg: $*" >&2
  exit 1
}

valid_path() {
  [[ "$1" == /* ]] && [[ "$1" != *$'\t'* ]] && [[ "$1" != *$'\n'* ]]
}

validate_value() {
  case "$1" in
    string) return 0 ;;
    int) [[ "$2" =~ ^-?[0-9]+$ ]] ;;
    real) [[ "$2" =~ ^-?([0-9]+([.][0-9]*)?|[.][0-9]+)$ ]] ;;
    bool) [[ "$2" == true || "$2" == false ]] ;;
    *) return 1 ;;
  esac
}

exists() {
  "$BDB" select registry --where "path=$1" 2>/dev/null |
    tail -n +2 | grep -q .
}

with_write_lock() {
  local i pid retries
  retries="${BDBREG_LOCK_RETRIES:-15}"
  for i in $(seq 1 "$retries"); do
    if mkdir "$WRITE_LOCK" 2>/dev/null; then
      echo "$$" >"$WRITE_LOCK/pid" 2>/dev/null || true
      trap 'rm -rf "$WRITE_LOCK" 2>/dev/null || true' EXIT INT TERM
      "$@"
      local status=$?
      rm -rf "$WRITE_LOCK" 2>/dev/null || true
      trap - EXIT INT TERM
      return "$status"
    fi
    pid="$(cat "$WRITE_LOCK/pid" 2>/dev/null || true)"
    if [ -z "$pid" ] || ! kill -0 "$pid" 2>/dev/null; then
      rm -rf "$WRITE_LOCK" 2>/dev/null || true
      continue
    fi
    sleep 1
  done
  die "registry write lock busy: $WRITE_LOCK"
}

cmd_list() {
  local prefix="${1:-/}"
  valid_path "$prefix" || die "chemin invalide: $prefix"
  printf '%-42s %-8s %-14s %s\n' PATH TYPE OWNER VALUE
  "$BDB" dump registry | tail -n +2 |
    awk -F '\t' -v p="$prefix" 'index($1, p) == 1 {
      printf "%-42s %-8s %-14s %s\n", $1, $2, $4, $3
    }'
}

cmd_get() {
  local path="${1:-}"
  valid_path "$path" || die "chemin invalide: $path"
  "$BDB" select registry --where "path=$path"
}

cmd_set_locked() {
  local path="${1:-}" type="${2:-}" value="${3-}" owner="${4:-operator}"
  valid_path "$path" || die "chemin invalide: $path"
  validate_value "$type" "$value" || die "valeur invalide pour le type $type"
  local now
  now=$(date +%s 2>/dev/null || echo 0)
  if exists "$path"; then
    "$BDB" update registry --where "path=$path" type="$type" value="$value" \
      owner="$owner" updated_at="$now" >/dev/null
  else
    "$BDB" insert registry path="$path" type="$type" value="$value" \
      owner="$owner" updated_at="$now" >/dev/null
  fi
  echo "bdbreg: set $path ($type)"
}

cmd_set() {
  with_write_lock cmd_set_locked "$@"
}

cmd_delete_locked() {
  local path="${1:-}"
  valid_path "$path" || die "chemin invalide: $path"
  "$BDB" delete registry --where "path=$path" >/dev/null
  echo "bdbreg: deleted $path"
}

cmd_delete() {
  with_write_lock cmd_delete_locked "$@"
}

command="${1:-help}"
shift || true
case "$command" in
  list) cmd_list "$@" ;;
  get) cmd_get "$@" ;;
  set) cmd_set "$@" ;;
  delete) cmd_delete "$@" ;;
  help|-h|--help) usage ;;
  *) usage >&2; exit 64 ;;
esac
