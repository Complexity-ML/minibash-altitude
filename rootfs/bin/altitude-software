#!/usr/bin/env gjs

imports.gi.versions.Gtk = '4.0';

const ByteArray = imports.byteArray;
const { Gio, GLib, Gtk } = imports.gi;

function bytesToString(bytes) {
    return bytes ? ByteArray.toString(bytes) : '';
}

function runCommand(argv) {
    try {
        const [ok, stdout, stderr, status] =
            GLib.spawn_sync(null, argv, null, GLib.SpawnFlags.SEARCH_PATH, null);
        const out = bytesToString(stdout);
        const err = bytesToString(stderr);
        return `$ ${argv.join(' ')}\n\n${out}${err}${ok ? '' : `\nexit: ${status}\n`}`;
    } catch (e) {
        return `$ ${argv.join(' ')}\n\n${e.message}\n`;
    }
}

const app = new Gtk.Application({
    application_id: 'org.altitude.Software',
    flags: Gio.ApplicationFlags.FLAGS_NONE,
});

app.connect('activate', application => {
    const win = new Gtk.ApplicationWindow({
        application,
        title: 'Altitude Software',
        default_width: 960,
        default_height: 680,
    });

    const root = new Gtk.Box({
        orientation: Gtk.Orientation.VERTICAL,
        spacing: 10,
        margin_top: 14,
        margin_bottom: 14,
        margin_start: 14,
        margin_end: 14,
    });

    const title = new Gtk.Label({
        label: '<b>Altitude Software</b>\nSigned Altitude packages, native apps and registry state.',
        use_markup: true,
        xalign: 0,
    });
    root.append(title);

    const toolbar = new Gtk.Box({
        orientation: Gtk.Orientation.HORIZONTAL,
        spacing: 8,
    });
    root.append(toolbar);

    const entry = new Gtk.Entry({
        placeholder_text: 'package name or search term',
        hexpand: true,
    });
    toolbar.append(entry);

    const view = new Gtk.TextView({
        editable: false,
        monospace: true,
        hexpand: true,
        vexpand: true,
    });
    const buffer = view.get_buffer();
    const scroller = new Gtk.ScrolledWindow({
        child: view,
        hexpand: true,
        vexpand: true,
    });
    root.append(scroller);

    function show(label, argv) {
        buffer.set_text(`${label}\n${'='.repeat(label.length)}\n\n${runCommand(argv)}`, -1);
    }

    function shell(script) {
        return ['/bin/bash', '-lc', script];
    }

    function term() {
        return entry.get_text().trim();
    }

    const actions = [
        ['Dashboard', () => show('Altitude Software Dashboard', shell(
            '/bin/registry-audit refresh 2>&1 || true; ' +
            '/bin/appreg refresh 2>&1 || true; ' +
            'echo; echo "== System =="; ' +
            '/bin/bdbreg list /system/product 2>&1; ' +
            'echo; /bin/bdbreg list /system/network 2>&1; ' +
            'echo; /bin/bdbreg list /system/desktop 2>&1; ' +
            'echo; echo "== Applications =="; ' +
            '/bin/appreg status 2>&1; ' +
            'echo; /bin/appreg list 2>&1; ' +
            'echo; echo "== Packages =="; ' +
            '/bin/pkg check-updates 2>&1'
        ))],
        ['Refresh', () => show('Refresh Repository', ['/bin/pkg', 'refresh'])],
        ['Search', () => show('Search Packages', ['/bin/pkg', 'search', term()])],
        ['Info', () => show('Package Info', ['/bin/pkg', 'info', term()])],
        ['Install', () => show('Install Package', ['/bin/pkg', 'install', term()])],
        ['Installed', () => show('Installed Packages', ['/bin/pkg', 'list'])],
        ['Updates', () => show('Package Updates', ['/bin/pkg', 'check-updates'])],
        ['Apps', () => show('Native Applications', shell(
            '/bin/appreg refresh 2>&1; echo; /bin/appreg status 2>&1; echo; /bin/appreg list 2>&1'
        ))],
        ['App Search', () => show('Search Applications', shell(
            `/bin/appreg refresh 2>&1; echo; /bin/appreg search ${GLib.shell_quote(term())} 2>&1`
        ))],
        ['Launch App', () => show('Launch Application', ['/bin/appreg', 'launch', term()])],
        ['Registry', () => show('Package Registry', shell(
            '/bin/bdbreg list /system/package 2>&1; echo; /bin/bdbreg list /system/apps 2>&1; echo; /bin/bdbreg list /system/init 2>&1'
        ))],
    ];

    for (const [label, callback] of actions) {
        const button = new Gtk.Button({ label });
        button.connect('clicked', callback);
        toolbar.append(button);
    }

    entry.connect('activate', () => show('Search Packages', ['/bin/pkg', 'search', term()]));

    win.set_child(root);
    win.present();
    show('Altitude Software Dashboard', shell(
        '/bin/registry-audit refresh 2>&1 || true; ' +
        '/bin/appreg refresh 2>&1 || true; ' +
        'echo; echo "== Applications =="; /bin/appreg status 2>&1; echo; /bin/appreg list 2>&1; ' +
        'echo; echo "== Packages =="; /bin/pkg check-updates 2>&1'
    ));
});

app.run(ARGV);
