#!/usr/bin/env gjs

imports.gi.versions.Gtk = '4.0';

const ByteArray = imports.byteArray;
const { Gio, GLib, Gtk } = imports.gi;

function bytesToString(bytes) {
    return bytes ? ByteArray.toString(bytes) : '';
}

function registryValue(path) {
    try {
        const [ok, stdout] = GLib.spawn_sync(
            null,
            ['/bin/bdbreg', 'get', path],
            null,
            GLib.SpawnFlags.SEARCH_PATH,
            null
        );
        if (!ok)
            return '';
        const lines = bytesToString(stdout).trim().split('\n');
        if (lines.length < 2)
            return '';
        const fields = lines[lines.length - 1].split('\t');
        return fields.length >= 3 ? fields[2] : '';
    } catch (e) {
        return '';
    }
}

function registrySet(path, type, value) {
    try {
        GLib.spawn_sync(
            null,
            ['/bin/bdbreg', 'set', path, type, String(value), 'altitude-command-runner'],
            null,
            GLib.SpawnFlags.SEARCH_PATH,
            null
        );
    } catch (e) {
    }
}

const app = new Gtk.Application({
    application_id: 'org.altitude.CommandRunner',
    flags: Gio.ApplicationFlags.FLAGS_NONE,
});

app.connect('activate', application => {
    const win = new Gtk.ApplicationWindow({
        application,
        title: 'Altitude Command Runner',
        default_width: 900,
        default_height: 560,
    });

    const root = new Gtk.Box({
        orientation: Gtk.Orientation.VERTICAL,
        spacing: 8,
        margin_top: 14,
        margin_bottom: 14,
        margin_start: 14,
        margin_end: 14,
    });

    const entry = new Gtk.Entry({
        text: 'ip -4 a',
        hexpand: true,
    });
    const runButton = new Gtk.Button({ label: 'Run' });
    const top = new Gtk.Box({
        orientation: Gtk.Orientation.HORIZONTAL,
        spacing: 8,
    });
    top.append(entry);
    top.append(runButton);
    root.append(top);

    const view = new Gtk.TextView({
        editable: false,
        monospace: true,
        hexpand: true,
        vexpand: true,
    });
    const buffer = view.get_buffer();
    root.append(new Gtk.ScrolledWindow({
        child: view,
        hexpand: true,
        vexpand: true,
    }));

    function run() {
        const command = entry.get_text();
        let text;
        let exitStatus = 0;
        try {
            const [ok, stdout, stderr, status] = GLib.spawn_sync(
                null,
                ['/bin/bash', '-lc', command],
                null,
                GLib.SpawnFlags.SEARCH_PATH,
                null
            );
            text = `$ ${command}\n\n${bytesToString(stdout)}${bytesToString(stderr)}`;
            exitStatus = status;
            if (!ok || exitStatus !== 0)
                text += `\nexit: ${exitStatus}\n`;
        } catch (e) {
            text = `$ ${command}\n\n${e.message}\n`;
            exitStatus = 1;
        }
        buffer.set_text(text, -1);
        try {
            GLib.file_set_contents('/run/altitude-command-runner.last', text);
        } catch (e) {
        }
        registrySet('/system/terminal/last/command', 'string', command);
        registrySet('/system/terminal/last/status', 'int', exitStatus);
        registrySet('/system/terminal/last/output-file', 'string', '/run/altitude-command-runner.last');
    }

    let lastRegistrySeq = registryValue('/system/terminal/inbox/seq');
    function pollRegistryInbox() {
        const seq = registryValue('/system/terminal/inbox/seq');
        if (seq !== '' && seq !== lastRegistrySeq) {
            lastRegistrySeq = seq;
            const command = registryValue('/system/terminal/inbox/command');
            if (command !== '') {
                entry.set_text(command);
                run();
            }
        }
        return GLib.SOURCE_CONTINUE;
    }

    runButton.connect('clicked', run);
    entry.connect('activate', run);
    GLib.timeout_add_seconds(GLib.PRIORITY_DEFAULT, 1, pollRegistryInbox);

    win.set_child(root);
    win.present();
    run();
});

app.run(ARGV);
