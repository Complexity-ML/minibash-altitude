#!/usr/bin/env bash
# BDBQL reference parser.
#
# This is intentionally Bash first: fast to evolve, easy to test, and backed by
# the stable bdb primitives. The C engine accelerates those primitives.
set -euo pipefail

BDB="${BDB_BIN:-/bin/bdb}"

die() {
  printf 'bdbql: %s\n' "$*" >&2
  exit 1
}

trim() {
  local s="$1"
  s="${s#"${s%%[![:space:]]*}"}"
  s="${s%"${s##*[![:space:]]}"}"
  printf '%s' "$s"
}

strip_value() {
  local v
  v="$(trim "$1")"
  if [[ "$v" == \'*\' && "$v" == *\' ]]; then
    v="${v:1:${#v}-2}"
  elif [[ "$v" == \"*\" && "$v" == *\" ]]; then
    v="${v:1:${#v}-2}"
  fi
  printf '%s' "$v"
}

is_name() {
  [[ "${1:-}" =~ ^[A-Za-z_][A-Za-z0-9_]*$ ]]
}

normalize_query() {
  local q="$*"
  q="$(trim "$q")"
  q="${q%;}"
  trim "$q"
}

where_arg() {
  local expr="$1" col val
  [[ "$expr" == *=* ]] || die "WHERE attend COL = VALUE"
  col="$(trim "${expr%%=*}")"
  val="$(strip_value "${expr#*=}")"
  is_name "$col" || die "colonne invalide: $col"
  printf '%s=%s' "$col" "$val"
}

assignments_from_insert() {
  local cols="$1" vals="$2" i col val
  local -a c v
  IFS=',' read -r -a c <<< "$cols"
  IFS=',' read -r -a v <<< "$vals"
  [ "${#c[@]}" -eq "${#v[@]}" ] || die "INSERT: nombre de colonnes/valeurs different"
  BDBQL_ASSIGNMENTS=()
  for ((i = 0; i < ${#c[@]}; i++)); do
    col="$(trim "${c[$i]}")"
    val="$(strip_value "${v[$i]}")"
    is_name "$col" || die "colonne invalide: $col"
    BDBQL_ASSIGNMENTS+=("$col=$val")
  done
}

assignments_from_set() {
  local set_expr="$1" part col val
  local -a parts
  IFS=',' read -r -a parts <<< "$set_expr"
  BDBQL_ASSIGNMENTS=()
  for part in "${parts[@]}"; do
    [[ "$part" == *=* ]] || die "SET attend COL = VALUE"
    col="$(trim "${part%%=*}")"
    val="$(strip_value "${part#*=}")"
    is_name "$col" || die "colonne invalide: $col"
    BDBQL_ASSIGNMENTS+=("$col=$val")
  done
}

exec_query() {
  local query="$1"
  local table col val cols vals set_expr where_expr
  local select_re insert_re update_re delete_re

  query="$(normalize_query "$query")"
  [ -n "$query" ] || return 0

  select_re='^SELECT[[:space:]]+\*[[:space:]]+FROM[[:space:]]+([A-Za-z_][A-Za-z0-9_]*)([[:space:]]+WHERE[[:space:]]+(.+))?$'
  insert_re='^INSERT[[:space:]]+INTO[[:space:]]+([A-Za-z_][A-Za-z0-9_]*)[[:space:]]*\(([^)]*)\)[[:space:]]+VALUES[[:space:]]*\((.*)\)$'
  update_re='^UPDATE[[:space:]]+([A-Za-z_][A-Za-z0-9_]*)[[:space:]]+SET[[:space:]]+(.+)[[:space:]]+WHERE[[:space:]]+(.+)$'
  delete_re='^DELETE[[:space:]]+FROM[[:space:]]+([A-Za-z_][A-Za-z0-9_]*)[[:space:]]+WHERE[[:space:]]+(.+)$'

  shopt -s nocasematch
  if [[ "$query" == "SHOW TABLES" ]]; then
    shopt -u nocasematch
    "$BDB" tables
  elif [[ "$query" =~ ^(DESC|DESCRIBE)[[:space:]]+([A-Za-z_][A-Za-z0-9_]*)$ ]]; then
    table="${BASH_REMATCH[2]}"
    shopt -u nocasematch
    "$BDB" schema "$table"
  elif [[ "$query" =~ $select_re ]]; then
    table="${BASH_REMATCH[1]}"
    where_expr="${BASH_REMATCH[3]:-}"
    shopt -u nocasematch
    if [ -n "$where_expr" ]; then
      "$BDB" select "$table" --where "$(where_arg "$where_expr")"
    else
      "$BDB" select "$table"
    fi
  elif [[ "$query" =~ $insert_re ]]; then
    table="${BASH_REMATCH[1]}"
    cols="${BASH_REMATCH[2]}"
    vals="${BASH_REMATCH[3]}"
    shopt -u nocasematch
    assignments_from_insert "$cols" "$vals"
    "$BDB" insert "$table" "${BDBQL_ASSIGNMENTS[@]}"
  elif [[ "$query" =~ $update_re ]]; then
    table="${BASH_REMATCH[1]}"
    set_expr="${BASH_REMATCH[2]}"
    where_expr="${BASH_REMATCH[3]}"
    shopt -u nocasematch
    assignments_from_set "$set_expr"
    "$BDB" update "$table" --where "$(where_arg "$where_expr")" "${BDBQL_ASSIGNMENTS[@]}"
  elif [[ "$query" =~ $delete_re ]]; then
    table="${BASH_REMATCH[1]}"
    where_expr="${BASH_REMATCH[2]}"
    shopt -u nocasematch
    "$BDB" delete "$table" --where "$(where_arg "$where_expr")"
  else
    shopt -u nocasematch
    die "syntaxe supportee: SHOW TABLES, DESC, SELECT *, INSERT, UPDATE, DELETE"
  fi
}

[ $# -gt 0 ] || die 'usage: bdbql "SELECT * FROM registry;"'
exec_query "$*"
