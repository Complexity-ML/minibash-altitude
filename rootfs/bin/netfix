#!/usr/bin/env bash
set -u
export PATH=/usr/sbin:/usr/bin:/sbin:/bin

[ -f /etc/minibash/wifi.creds ] && . /etc/minibash/wifi.creds
SSID="${WIFI_SSID:-Livebox-E130}"
PSK="${WIFI_PSK:-}"

log() { echo "netfix: $*"; }

detect_wifi_if() {
  local dev
  for dev in /sys/class/net/*; do
    [ -d "$dev/wireless" ] || continue
    basename "$dev"
    return 0
  done
  return 1
}

mkdir -p /etc/NetworkManager/conf.d /run/dbus /run/NetworkManager /var/lib/NetworkManager
cat > /etc/NetworkManager/NetworkManager.conf <<'EOF'
[main]
plugins=keyfile

[ifupdown]
managed=true

[keyfile]
unmanaged-devices=none
EOF
cat > /etc/NetworkManager/conf.d/10-minibash.conf <<'EOF'
[main]
plugins=keyfile

[ifupdown]
managed=true

[keyfile]
unmanaged-devices=none

[device-wifi]
match-device=type:wifi
managed=1

[device-ethernet]
match-device=type:ethernet
managed=1
EOF

for mod in \
  cfg80211 mac80211 rfkill \
  iwlwifi iwlmvm iwldvm \
  rtw88_core rtw88_pci rtw89_core rtw89_pci rtl8xxxu \
  ath9k ath10k_pci ath11k_pci \
  brcmfmac brcmsmac \
  mt76 mt7921e mt7921u mt7925e; do
  modprobe "$mod" 2>/dev/null || true
done
rfkill unblock all 2>/dev/null || true

IF="$(detect_wifi_if || true)"
[ -n "$IF" ] || {
  log "no wifi interface"
  dmesg 2>/dev/null | grep -Ei 'firmware|wifi|wlan|iwlwifi|rtw|rtl|ath|brcm|mt76|mt792' | tail -60
  exit 1
}
log "wifi interface: $IF"
iw reg set FR 2>/dev/null || true
ip link set "$IF" up 2>/dev/null || true

[ -S /run/dbus/system_bus_socket ] || dbus-daemon --system --fork 2>/dev/null || true
pkill -x NetworkManager 2>/dev/null || true
sleep 1
NetworkManager --no-daemon >/var/log/NetworkManager-live.log 2>&1 &
sleep 5

nmcli radio wifi on || true
nmcli networking on || true
nmcli device set "$IF" autoconnect yes || true
nmcli device set "$IF" managed yes || true
nmcli general reload || true
ip link set "$IF" up 2>/dev/null || true
sleep 2
nmcli device status
iw dev "$IF" scan ssid "$SSID" >/tmp/netfix-iw-scan.log 2>&1 || true
nmcli device wifi rescan ifname "$IF" 2>/dev/null || nmcli device wifi rescan || true
nmcli device wifi list ifname "$IF" 2>/dev/null || nmcli device wifi list || true
nmcli device wifi connect "$SSID" password "$PSK" ifname "$IF" || nmcli connection up "$SSID"
sleep 3
if ip -4 addr show "$IF" | grep -q 'inet '; then
  ip -4 addr show "$IF"
  exit 0
fi

log "NetworkManager did not get an IP; falling back to wpa_supplicant + udhcpc"
killall NetworkManager 2>/dev/null || true
killall wpa_supplicant 2>/dev/null || true
mkdir -p /run/wpa_supplicant
cat > /tmp/netfix-wpa.conf <<EOF
ctrl_interface=/run/wpa_supplicant
update_config=0
network={
    ssid="$SSID"
    psk="$PSK"
    key_mgmt=SAE WPA-PSK
    ieee80211w=1
}
EOF
wpa_supplicant -i "$IF" -c /tmp/netfix-wpa.conf -Dnl80211 >/var/log/wpa_supplicant-netfix.log 2>&1 &
sleep 12
if ! iw dev "$IF" link 2>/dev/null | grep -q '^Connected'; then
  log "WPA3/WPA2 failed; retrying WPA2-only"
  killall wpa_supplicant 2>/dev/null || true
  cat > /tmp/netfix-wpa.conf <<EOF
ctrl_interface=/run/wpa_supplicant
update_config=0
network={
    ssid="$SSID"
    psk="$PSK"
    key_mgmt=WPA-PSK
    proto=RSN
    pairwise=CCMP
    group=CCMP TKIP
    ieee80211w=0
}
EOF
  wpa_supplicant -i "$IF" -c /tmp/netfix-wpa.conf -Dnl80211 >/var/log/wpa_supplicant-netfix.log 2>&1 &
  sleep 12
fi
iw dev "$IF" link 2>/dev/null || true
busybox udhcpc -i "$IF" -s /usr/share/udhcpc/default.script -t 10 -A 3 -n >/var/log/udhcpc-netfix.log 2>&1 || true
ip -4 addr show "$IF"
ip route
tail -40 /var/log/wpa_supplicant-netfix.log 2>/dev/null || true
tail -40 /var/log/udhcpc-netfix.log 2>/dev/null || true
