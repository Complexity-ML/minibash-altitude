#!/usr/bin/env bash
set -euo pipefail

POLICY="${ALTITUDE_AGENT_POLICY:-/etc/altitude/agent/policy.conf}"
[ -r "$POLICY" ] && . "$POLICY"

SOURCE_ROOT="${ALTITUDE_AGENT_SOURCE_ROOT:-/root/minibash-linux}"
TARGET="${1:-$SOURCE_ROOT}"
KEYBOARD_LAYOUT="${ALTITUDE_KEYBOARD_LAYOUT:-}"

if [ -z "$KEYBOARD_LAYOUT" ] && [ -x /bin/alt-keyboard-layout ]; then
  KEYBOARD_LAYOUT="$(/bin/alt-keyboard-layout 2>/dev/null || true)"
fi

if [ -n "$KEYBOARD_LAYOUT" ]; then
  export ALTITUDE_KEYBOARD_LAYOUT="$KEYBOARD_LAYOUT"
  export XKB_DEFAULT_LAYOUT="${XKB_DEFAULT_LAYOUT:-$KEYBOARD_LAYOUT}"
fi

if ! command -v vim >/dev/null 2>&1; then
  echo "Altitude Vim IDE needs /usr/bin/vim."
  echo "Install it with: pkg install altitude-vim"
  exit 69
fi

if command -v kgx >/dev/null 2>&1; then
  exec kgx --working-directory="$SOURCE_ROOT" -- /bin/alt-vim "$TARGET"
fi

cd "$SOURCE_ROOT"
exec /bin/alt-vim "$TARGET"
